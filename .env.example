# Copier ce fichier en ".env" et remplir de vraies valeurs. Ne jamais commiter le ".env" reel.

# Port d'ecoute local du serveur Node (nginx fait le reverse proxy en HTTPS devant)
PORT=3000

# true en production derriere nginx en HTTPS (active les cookies "secure")
TRUST_PROXY=false
COOKIE_SECURE=false

# Genere avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-generate-a-real-random-secret
CSRF_SECRET=change-me-generate-another-real-random-secret

# Domaine public du site (utilise pour le cookie de session en prod), ex: fabrics-metz.fr
COOKIE_DOMAIN=

# Envoi des messages du formulaire de contact via votre propre serveur mail (SMTP).
# Si SMTP_HOST est vide, les messages sont quand meme enregistres en base et
# consultables dans /admin, mais aucun email n'est envoye.
# Exemple pour rezo-rm.fr (MX = mail.rezo-rm.fr, port 587/STARTTLS confirme ouvert) :
SMTP_HOST=mail.rezo-rm.fr
SMTP_PORT=587
# true pour TLS implicite (port 465), false pour STARTTLS (port 587) ou relais local (port 25)
SMTP_SECURE=false
# Identifiant/mot de passe d'un compte mail existant sur ce serveur (a demander a
# l'administrateur de rezo-rm.fr si vous ne les avez pas)
SMTP_USER=
SMTP_PASSWORD=

# Adresse d'expedition (doit generalement appartenir au domaine de votre serveur mail)
MAIL_FROM=contact@rezo-rm.fr
# Adresse (ou liste de diffusion) qui recoit les messages du formulaire "Rejoindre"
CONTACT_MAILING_LIST=liste@rezo-rm.fr
